{
  "name": "xaligo-vscode-extension",
  "displayName": "xaligo",
  "description": "VS Code language support, interactive preview, and structural diff for the xaligo .xal diagram DSL.",
  "version": "0.0.13",
  "publisher": "xaligo",
  "license": "MIT",
  "icon": "assets/xaligo-icon-vscode-128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/xaligo/xaligo-vscode-extension.git"
  },
  "homepage": "https://github.com/xaligo/xaligo-vscode-extension#readme",
  "bugs": {
    "url": "https://github.com/xaligo/xaligo-vscode-extension/issues"
  },
  "qna": false,
  "xaligo": {
    "packageName": "@xaligo/xaligo",
    "packageRoot": "node_modules/@xaligo/xaligo",
    "nativeBinaryDir": "bin/native",
    "nativeBinaryPlatformNames": {
      "win32": "windows"
    },
    "nativeBinaryArchNames": {
      "x64": "amd64"
    },
    "vsixNativeBinaryTargets": [
      {
        "platform": "darwin",
        "arch": "x64"
      },
      {
        "platform": "darwin",
        "arch": "arm64"
      },
      {
        "platform": "linux",
        "arch": "x64"
      },
      {
        "platform": "linux",
        "arch": "arm64"
      },
      {
        "platform": "win32",
        "arch": "x64"
      },
      {
        "platform": "win32",
        "arch": "arm64"
      }
    ]
  },
  "galleryBanner": {
    "color": "#0b2f73",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "xaligo",
    "xal",
    "diagram",
    "syntax",
    "preview",
    "structural-diff"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:xal",
    "onCommand:xaligo.openPreview",
    "onCommand:xaligo.openDiffPreview",
    "onCommand:xaligo.preview.zoomIn",
    "onCommand:xaligo.preview.zoomOut",
    "onCommand:xaligo.preview.resetZoom",
    "onCommand:xaligo.preview.resetView",
    "onCommand:xaligo.preview.close",
    "onCommand:xaligo.exportSvg",
    "onCommand:xaligo.exportPptx",
    "onCommand:xaligo.exportExcalidraw",
    "onCommand:xaligo.selectFileIconTheme"
  ],
  "main": "./dist/extension/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "xal",
        "aliases": [
          "xaligo",
          "Xaligo",
          "xal"
        ],
        "extensions": [
          ".xal"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./assets/xaligo-file-icon.png",
          "dark": "./assets/xaligo-file-icon.png"
        }
      }
    ],
    "iconThemes": [
      {
        "id": "xaligo-icons",
        "label": "xaligo",
        "path": "./fileicons/xaligo-icon-theme.json"
      }
    ],
    "grammars": [
      {
        "language": "xal",
        "scopeName": "text.xml.xaligo",
        "path": "./syntaxes/xal.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "xaligo.openPreview",
        "title": "Open Preview",
        "category": "xaligo"
      },
      {
        "command": "xaligo.openDiffPreview",
        "title": "Open Structural Diff",
        "category": "xaligo",
        "icon": "$(diff)"
      },
      {
        "command": "xaligo.preview.zoomIn",
        "title": "Zoom In",
        "category": "xaligo",
        "icon": "$(zoom-in)"
      },
      {
        "command": "xaligo.preview.zoomOut",
        "title": "Zoom Out",
        "category": "xaligo",
        "icon": "$(zoom-out)"
      },
      {
        "command": "xaligo.preview.resetZoom",
        "title": "Reset Zoom",
        "category": "xaligo",
        "icon": "$(screen-normal)"
      },
      {
        "command": "xaligo.preview.resetView",
        "title": "Reset View",
        "category": "xaligo",
        "icon": "$(home)"
      },
      {
        "command": "xaligo.preview.close",
        "title": "Close Preview",
        "category": "xaligo",
        "icon": "$(close)"
      },
      {
        "command": "xaligo.exportSvg",
        "title": "Export as SVG",
        "category": "xaligo",
        "icon": "$(file-code)"
      },
      {
        "command": "xaligo.exportPptx",
        "title": "Export as PPTX",
        "category": "xaligo",
        "icon": "$(file-media)"
      },
      {
        "command": "xaligo.exportExcalidraw",
        "title": "Export as Excalidraw",
        "category": "xaligo",
        "icon": "$(json)"
      },
      {
        "command": "xaligo.selectFileIconTheme",
        "title": "Select File Icon Theme",
        "category": "xaligo",
        "icon": "$(symbol-color)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "xaligo.openPreview",
          "when": "resourceLangId == xal",
          "group": "navigation@1"
        },
        {
          "command": "xaligo.openDiffPreview",
          "when": "resourceLangId == xal",
          "group": "navigation@2"
        },
        {
          "command": "xaligo.exportSvg",
          "when": "resourceLangId == xal",
          "group": "navigation@3"
        },
        {
          "command": "xaligo.exportPptx",
          "when": "resourceLangId == xal",
          "group": "navigation@4"
        },
        {
          "command": "xaligo.exportExcalidraw",
          "when": "resourceLangId == xal",
          "group": "navigation@5"
        }
      ],
      "editor/context": [
        {
          "command": "xaligo.openPreview",
          "when": "resourceLangId == xal",
          "group": "navigation@1"
        },
        {
          "command": "xaligo.openDiffPreview",
          "when": "resourceLangId == xal",
          "group": "navigation@2"
        },
        {
          "command": "xaligo.exportSvg",
          "when": "resourceLangId == xal",
          "group": "navigation@3"
        },
        {
          "command": "xaligo.exportPptx",
          "when": "resourceLangId == xal",
          "group": "navigation@4"
        },
        {
          "command": "xaligo.exportExcalidraw",
          "when": "resourceLangId == xal",
          "group": "navigation@5"
        }
      ],
      "webview/title": [
        {
          "command": "xaligo.preview.zoomOut",
          "when": "webviewId == 'xaligoPreview'",
          "group": "navigation@1"
        },
        {
          "command": "xaligo.preview.resetZoom",
          "when": "webviewId == 'xaligoPreview'",
          "group": "navigation@2"
        },
        {
          "command": "xaligo.preview.zoomIn",
          "when": "webviewId == 'xaligoPreview'",
          "group": "navigation@3"
        },
        {
          "command": "xaligo.preview.resetView",
          "when": "webviewId == 'xaligoPreview'",
          "group": "navigation@4"
        },
        {
          "command": "xaligo.preview.close",
          "when": "webviewId == 'xaligoPreview'",
          "group": "navigation@5"
        }
      ]
    },
    "configuration": {
      "title": "xaligo",
      "properties": {
        "xaligo.executablePath": {
          "type": "string",
          "default": "",
          "scope": "machine-overridable",
          "description": "Absolute path to a xaligo native CLI. Leave empty to use the renderer bundled with the extension. Structural diff requires xaligo 0.1.21 or newer."
        }
      }
    }
  },
  "scripts": {
    "build": "node scripts/clean-dist.cjs && vite build && vite build --config vite.webview.config.ts",
    "watch": "vite build --watch",
    "watch:webview": "vite build --config vite.webview.config.ts --watch",
    "test": "vitest run",
    "check:renderer": "node scripts/check-native-renderer.cjs",
    "typecheck": "tsc --noEmit",
    "package": "node scripts/prepare-vsix-native-binaries.cjs && vsce package",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@xaligo/xaligo": "^0.1.21"
  }
}
